# =========================================================================
# Dmassa - variaveis de ambiente
# Copie este arquivo para .env e ajuste os valores.
# =========================================================================

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=dmassa
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------------
REDIS_PASSWORD=troque-esta-senha
REDIS_PORT=6379

# --- MinIO (armazenamento de midias) --------------------------------------
MINIO_ROOT_USER=dmassa
MINIO_ROOT_PASSWORD=troque-esta-senha-minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=dmassa-media

# --- Evolution API --------------------------------------------------------
EVOLUTION_PORT=8080
EVOLUTION_URL=http://localhost:8080
# Chave global do Evolution. GERE ALGO FORTE em producao (32+ chars).
EVOLUTION_API_KEY=troque-esta-chave-evolution

# URL do webhook que o Evolution vai chamar.
# Em dev (Windows/Mac): http://host.docker.internal:3000
# Em producao (VPS c/ Caddy):  https://seu-dominio ou https://ip-com-hifen.sslip.io
# Sempre inclua ?token=... e o token deve bater com WEBHOOK_TOKEN abaixo.
WEBHOOK_URL=http://host.docker.internal:3000/api/webhooks/evolution?token=troque-este-token
WEBHOOK_TOKEN=troque-este-token

# =========================================================================
# App Next.js
# =========================================================================

# --- Banco do app ---------------------------------------------------------
DATABASE_URL=postgresql://dmassa:troque-esta-senha@localhost:5432/dmassa?schema=public

# --- Redis (para BullMQ) --------------------------------------------------
REDIS_URL=redis://:troque-esta-senha@localhost:6379/0

# --- MinIO (SDK S3) -------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=dmassa
S3_SECRET_KEY=troque-esta-senha-minio
S3_BUCKET=dmassa-media
# URL publica dos arquivos. Em producao, aponte para um dominio publico
# (ex.: https://media.seu-dominio) ou mantenha via reverse proxy.
S3_PUBLIC_URL=http://localhost:9000/dmassa-media

# --- Evolution (do lado do app) -------------------------------------------
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_GLOBAL_API_KEY=troque-esta-chave-evolution

# --- Sessao (cookie assinado) --------------------------------------------
# GERE com: openssl rand -base64 48 (minimo 32 caracteres)
SESSION_PASSWORD=troque-por-32-caracteres-ou-mais-de-entropia-aleatoria

# --- Usuario admin inicial (usado pelo seed) -----------------------------
SEED_ADMIN_EMAIL=admin@dmassa.local
SEED_ADMIN_PASSWORD=troque-esta-senha-forte
SEED_ADMIN_NAME=Admin

# --- Comportamento padrao de disparo (fallbacks) --------------------------
DEFAULT_DELAY_MIN_SEC=5
DEFAULT_DELAY_MAX_SEC=15
DEFAULT_REST_EVERY_N=20
DEFAULT_REST_FOR_SEC=600
# Ajuste automatico para instancias marcadas como "enterprise".
ENTERPRISE_EXTRA_DELAY_TEXT_SEC=30
ENTERPRISE_EXTRA_DELAY_MEDIA_SEC=90
# Janela padrao de disparo (horario local do servidor).
DEFAULT_ALLOWED_HOUR_START=8
DEFAULT_ALLOWED_HOUR_END=20
